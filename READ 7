§12 — CORS Posture
const CORS_ALLOWLIST_PATTERNS = [
  /^http:\/\/localhost(:\d+)?$/,
  /^http:\/\/127\.0\.0\.1(:\d+)?$/,
  /^https:\/\/[a-z0-9-]+\.workers\.dev$/i,  // operator's Worker B subdomain
  /^https:\/\/claude\.ai$/,                  // cookie-bridge mode
];

function corsHeadersFor(req) {
  const origin = req.headers.get('Origin');
  if (!origin) return {};
  const allowed = CORS_ALLOWLIST_PATTERNS.some(re => re.test(origin));
  if (!allowed) return {};
  return {
    'Access-Control-Allow-Origin': origin,
    'Access-Control-Allow-Credentials': 'true',
    'Access-Control-Allow-Methods': 'GET, POST, PUT, DELETE, OPTIONS',
    'Access-Control-Allow-Headers': 'content-type, x-api-key, authorization, anthropic-version, x-hackerone-handle',
    'Access-Control-Expose-Headers':
      'x-wc-system-stripped, x-wc-mutation-mode, x-wc-canary-injected, ' +
      'x-wc-canary-echoed, x-wc-original-system-len, x-wc-final-system-len, ' +
      'x-wc-routing-mode, x-wc-request-id, request-id',
    'Vary': 'Origin',
  };
}

function handleOptions(req) {
  return new Response(null, { status: 204, headers: corsHeadersFor(req) });
}
Access-Control-Allow-Credentials: true is set only when the explicit allowed origin matches — never *, because Workers' Fetch API treats wildcard with credentials as forbidden per the standard.

§13 — Egress Posture & Outbound Fetch Wrap
function safeOutboundFetch(url, init) {
  const u = new URL(url);
  if (BLOCKED_HOSTS.includes(u.hostname.toLowerCase())) {
    throw new InterceptError(403, `BLOCKED_HOSTS: ${u.hostname}`);
  }
  return fetch(url, init);
}
Every outbound fetch in Worker C goes through safeOutboundFetch. The function is monomorphic (one URL, one init) so the runtime can inline it; a code reviewer can grep -n 'safeOutboundFetch\|^[[:space:]]*fetch(' worker_c_cf.js and reject any raw fetch( call to a non-CDN URL.

Anthropic domains (api.anthropic.com, console.anthropic.com, platform.claude.com) are not in BLOCKED_HOSTS — passthrough mode legitimately needs api.anthropic.com reachability with the operator's own credentials. Per Anthropic's HackerOne program research guidelines, operators must include their X-HackerOne-Handle on requests, only test their own account, and avoid exfiltration. Worker C's passthrough mode injects the handle automatically (§3.1).

§14 — Top-Level Dispatcher
// =============================================================================
// §14 TOP-LEVEL FETCH HANDLER
// =============================================================================

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const method = request.method;

    // CORS preflight
    if (method === 'OPTIONS') return handleOptions(request);

    try {
      // Operator-only diagnostic surface
      if (url.pathname === '/health') {
        return withCORS(await handleHealth(env), request);
      }
      if (url.pathname === '/setup' && method === 'GET') {
        return withCORS(await renderSetupPage(env, await loadConfig(env)), request);
      }
      if (url.pathname === '/api/worker-config' && method === 'POST') {
        return withCORS(await handleSetupPost(request, env), request);
      }
      if (url.pathname === '/intercept-log' && method === 'GET') {
        return withCORS(await handleInterceptLog(request, env), request);
      }
      if (url.pathname === '/intercept-log' && method === 'DELETE') {
        return withCORS(await handleDeleteLog(request, env), request);
      }

      // The intercept path — /v1/messages or /api/organizations/.../completion
      if (isInterceptablePath(url.pathname)) {
        return await handleIntercept(request, env, ctx);
      }

      // Everything else passes through unmodified to the configured upstream
      return await handlePassthroughNonIntercept(request, env, ctx);

    } catch (err) {
      const status = err.status || 500;
      const body = JSON.stringify({
        error: { type: 'worker_c_error', message: err.message }
      });
      return withCORS(new Response(body, {
        status,
        headers: { 'content-type': 'application/json' }
      }), request);
    }
  }
};

function isInterceptablePath(p) {
  return p === '/v1/messages'
      || /^\/api\/organizations\/[^\/]+\/chat_conversations\/[^\/]+\/completion$/.test(p);
}

function withCORS(resp, request) {
  const cors = corsHeadersFor(request);
  const h = new Headers(resp.headers);
  for (const [k, v] of Object.entries(cors)) h.set(k, v);
  return new Response(resp.body, { status: resp.status, headers: h });
}

async function loadConfig(env) {
  return JSON.parse((await env.WC_KV.get('WC_CONFIG')) || '{}');
}
§14.1 The intercept handler
async function handleIntercept(request, env, ctx) {
  const startTs = Date.now();
  const request_id = newRequestId();
  const cfg = await loadConfig(env);
  const mode = (cfg.WC_MODE || 'passthrough').toLowerCase();
  const route = (cfg.WC_ROUTE || 'test').toLowerCase();
  const url = new URL(request.url);

  // Read + mutate body
  const bodyText = await request.text();
  let parsed;
  try { parsed = JSON.parse(bodyText); }
  catch { return new Response('invalid JSON', { status: 400 }); }

  const { mutated, original_system, final_system, canary } =
    applyMutation(parsed, { ...env, ...cfg }, mode);

  // Resolve upstream
  const { url: upstreamUrl } = resolveUpstream({ ...env, ...cfg }, url.pathname + url.search);
  const upstreamHeaders = buildUpstreamHeaders(request, { ...env, ...cfg }, route);
  upstreamHeaders.set('content-type', 'application/json');

  // Dispatch
  const upstream = await safeOutboundFetch(upstreamUrl, {
    method: request.method,
    headers: upstreamHeaders,
    body: JSON.stringify(mutated),
  });

  // Build evidence + log meta
  const meta = {
    request_id,
    ts: startTs,
    pathname: url.pathname,
    method: request.method,
    routing_mode: route,
    mutation_mode: mode,
    original_system,
    final_system,
    canary,
    request_body_redacted: redactBodyFields(parsed),
    response_status: upstream.status,
    response_time_ms: Date.now() - startTs,
    upstream_request_id: upstream.headers.get('request-id') || null,
    mode, route, // shorthand for header builder
  };

  // Initial log write — scanStream will overwrite with terminal state
  if (env.WC_KV_LOG === 'true' || cfg.WC_KV_LOG === 'true') {
    ctx.waitUntil(env.WC_KV.put(
      `log:${startTs}:${request_id}`,
      JSON.stringify(meta),
      { expirationTtl: 60*86400 }
    ));
  }

  // Stream the response back through the tee pipeline
  const ct = upstream.headers.get('content-type') || '';
  if (ct.includes('text/event-stream')) {
    return pipeStreamingResponse(upstream, meta, { ...env, ...cfg }, ctx);
  }
  // Non-streaming path
  const buf = await upstream.arrayBuffer();
  const preview = new TextDecoder().decode(buf.slice(0, 4096));
  meta.response_body_preview = preview;
  if (env.WC_KV_LOG === 'true' || cfg.WC_KV_LOG === 'true') {
    ctx.waitUntil(env.WC_KV.put(
      `log:${startTs}:${request_id}`,
      JSON.stringify(meta),
      { expirationTtl: 60*86400 }
    ));
  }
  return new Response(buf, {
    status: upstream.status,
    headers: mergeEvidenceHeaders(upstream.headers, meta)
  });
}
