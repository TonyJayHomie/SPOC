async function writeLog(env, ctx, entry) {
  if (env.WC_KV_LOG !== 'true') return;
  const key = `log:${entry.ts}:${entry.request_id}`;
  // 60-day TTL on log entries
  ctx.waitUntil(env.WC_KV.put(key, JSON.stringify(entry), { expirationTtl: 60*86400 }));
}
§6.4 GET /intercept-log handler
async function handleInterceptLog(req, env) {
  const url = new URL(req.url);
  const limit = Math.min(parseInt(url.searchParams.get('limit') || '50'), 1000);
  const cursor = url.searchParams.get('cursor') || undefined;
  const reqId = url.searchParams.get('request_id');

  if (reqId) {
    // Direct lookup by request_id (linear scan of recent keys)
    const list = await env.WC_KV.list({ prefix: 'log:', limit: 1000 });
    for (const k of list.keys) {
      if (k.name.endsWith(':' + reqId)) {
        const v = await env.WC_KV.get(k.name);
        return new Response(v, { headers: { 'content-type': 'application/json' } });
      }
    }
    return new Response('not found', { status: 404 });
  }

  const list = await env.WC_KV.list({ prefix: 'log:', limit, cursor });
  const entries = [];
  for (const k of list.keys) {
    const v = await env.WC_KV.get(k.name);
    if (v) entries.push(JSON.parse(v));
  }
  return new Response(JSON.stringify({
    entries,
    list_complete: list.list_complete,
    cursor: list.cursor
  }), { headers: { 'content-type': 'application/json' } });
}
This pattern follows Cloudflare KV list() pagination guidance4: callers paginate by passing back the returned cursor, and list_complete signals end of results.

§6.5 DELETE /intercept-log
async function handleDeleteLog(req, env) {
  let cursor;
  let deleted = 0;
  while (true) {
    const list = await env.WC_KV.list({ prefix: 'log:', limit: 1000, cursor });
    for (const k of list.keys) {
      await env.WC_KV.delete(k.name);
      deleted++;
    }
    if (list.list_complete) break;
    cursor = list.cursor;
  }
  return new Response(JSON.stringify({ deleted }),
                      { headers: { 'content-type': 'application/json' } });
}
§7 — SSE Re-Streaming Pipeline (the load-bearing primitive)
This is the most subtle part of Worker C. Two non-negotiable properties:

Byte-for-byte fidelity. The response that Worker B's SSE consumer sees must be byte-identical to what Worker A / api.anthropic.com produced (modulo the evidence headers Worker C adds). Any reformatting will break tool-use partial-JSON accumulation.
No buffering. Each chunk must reach the client as soon as it arrives upstream. Buffering the whole stream would defeat the streaming UX and could timeout the Worker.
§7.1 Why TransformStream + tee
Per Cloudflare Workers TransformStream docs5, Workers currently provides an identity transform stream that "forwards all chunks of byte data (in the form of TypedArrays) written to its writable side to its readable side, without any changes." The recommended class is IdentityTransformStream with BYOB read support.

Per MDN ReadableStream.tee()6, tee() returns a two-element array of new ReadableStreams. Backpressure caveat: tee'd streams partially signal backpressure at the rate of the faster consumer, with unread data enqueued internally on the slower branch without limit. For Worker C's case, both branches are consumed at near-identical speeds (one to the client, one to the canary scanner — which is just substring matching on decoded text), so this is safe. If the canary branch ever stalls, the doc warns that "the entire body will be enqueued in memory."

§7.2 SSE pipeline — code skeleton
// =============================================================================
// §7 SSE TEE PIPELINE
// =============================================================================

async function pipeStreamingResponse(upstream, meta, env, ctx) {
  if (!upstream.body) {
    // Non-streaming fallback
    const buf = await upstream.arrayBuffer();
    ctx.waitUntil(writeNonStreamingLog(env, meta, upstream.status, buf));
    return new Response(buf, {
      status: upstream.status,
      headers: mergeEvidenceHeaders(upstream.headers, meta)
    });
  }

  // Tee the upstream body — one branch to client, one to canary scanner.
  const [toClient, toScanner] = upstream.body.tee();

  // Run the canary scanner / event counter in waitUntil so it doesn't
  // block the client response.
  ctx.waitUntil(scanStream(toScanner, meta, env));

  // Identity passthrough for the client branch — preserves byte boundaries.
  const { readable, writable } = new IdentityTransformStream();
  toClient.pipeTo(writable).catch(err => {
    // Client disconnect or upstream abort — log but don't crash
    console.log('client pipe aborted:', err.message);
  });

  return new Response(readable, {
    status: upstream.status,
    headers: mergeEvidenceHeaders(upstream.headers, meta)
  });
}

function mergeEvidenceHeaders(upstreamHeaders, meta) {
  const h = new Headers(upstreamHeaders);
  // Strip CF-injected headers from upstream
  ['cf-cache-status','cf-ray','server-timing'].forEach(k => h.delete(k));
  // Add evidence headers
  for (const [k, v] of buildEvidenceHeaders(meta).entries()) {
    h.set(k, v);
  }
  // Preserve the upstream content-type (text/event-stream; charset=utf-8)
  return h;
}
The pipeTo(...).catch(...) pattern is necessary because client disconnects propagate as AbortError and would otherwise crash the request. The tee'd toScanner branch keeps its own internal queue and finishes naturally even if the client branch aborts early — this is exactly the use case described in MDN's ServiceWorker tee example6.

§8 — Canary Detector
Runs on the toScanner branch in ctx.waitUntil. Decodes UTF-8, parses SSE events, scans only the text_delta payloads for the canary string. Updates the KV log entry with canary_echoed_in_response: true|false once the stream completes.

§8.1 Canary detector — code skeleton
// =============================================================================
// §8 CANARY DETECTOR + SSE STATE MACHINE
// =============================================================================

async function scanStream(stream, meta, env) {
  const reader = stream.getReader();
  const decoder = new TextDecoder('utf-8', { stream: true });
  let buf = '';
  let eventCount = 0;
  let canaryEchoed = false;
  let messageStart = null;
  let stopReason = null;
  let outputTokens = 0;

  // Per-block tool-use partial-JSON accumulators
  const toolBuf = Object.create(null);

  try {
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += decoder.decode(value, { stream: true });

      // SSE frames are separated by \n\n
      let idx;
      while ((idx = buf.indexOf('\n\n')) !== -1) {
        const frame = buf.slice(0, idx);
        buf = buf.slice(idx + 2);
        eventCount++;
        const parsed = parseSSEFrame(frame);
        if (!parsed) continue;
        const { event, data } = parsed;

        switch (event) {
          case 'message_start':
            messageStart = data?.message ?? null;
            break;
          case 'content_block_start':
            if (data?.content_block?.type === 'tool_use') {
              toolBuf[data.index] = '';
            }
            break;
          case 'content_block_delta': {
            const d = data?.delta;
            if (d?.type === 'text_delta' && typeof d.text === 'string') {
              if (meta.canary && d.text.includes(meta.canary)) {
                canaryEchoed = true;
              }
            } else if (d?.type === 'input_json_delta' &&
                       typeof d.partial_json === 'string') {
              toolBuf[data.index] = (toolBuf[data.index]||'') + d.partial_json;
            }
            break;
          }
          case 'content_block_stop':
            // toolBuf[data.index] is now complete JSON if the block was tool_use
            break;
          case 'message_delta':
            stopReason = data?.delta?.stop_reason ?? null;
            outputTokens = data?.usage?.output_tokens ?? outputTokens;
            break;
          case 'message_stop':
            // final
            break;
          case 'ping':
            // no-op; appears every ~15s, must be tolerated anywhere in stream
            break;
          case 'error':
            // mid-stream error; stream ends without message_stop
            break;
        }
      }
    }
  } catch (err) {
    // tee branch can be aborted by upstream; record what we have
    canaryEchoed = canaryEchoed; // keep current value
  }

  // Update KV with terminal state
  const entry = {
    ...meta,
    sse_event_count: eventCount,
    canary_echoed_in_response: meta.canary ? canaryEchoed : null,
    stop_reason: stopReason,
    output_tokens: outputTokens,
  };
  if (env.WC_KV_LOG === 'true') {
    const key = `log:${meta.ts}:${meta.request_id}`;
    await env.WC_KV.put(key, JSON.stringify(entry),
                        { expirationTtl: 60*86400 });
  }
}

function parseSSEFrame(frame) {
  // Frame is "event: <name>\ndata: <json>"
  const lines = frame.split('\n');
  let event = null, data = null;
  for (const line of lines) {
    if (line.startsWith('event: ')) event = line.slice(7).trim();
    else if (line.startsWith('data: ')) {
      const raw = line.slice(6);
      try { data = JSON.parse(raw); } catch { data = raw; }
    }
  }
  return event ? { event, data } : null;
}
§8.2 Anthropic SSE event taxonomy
Anchored to the public Anthropic streaming spec as documented in Claude Code Internals Part 77 (which reverse-engineers Claude Code v2.0.76's stream processor) and the anthropic-sdk-python _messages.py source which enforces message_start ordering (anthropic-sdk-python8).

Standard sequence:

message_start
  └─ message: { id:"msg_...", model, role, content:[], usage:{input_tokens,...} }

content_block_start    (index 0, type:"text"  or  index N, type:"tool_use")
  ├─ ping              (every ~15s, tolerable anywhere)
  ├─ content_block_delta (text_delta  OR  input_json_delta)
  │     ...repeat...
  └─ content_block_stop

  ...repeat content_block_* per output block...

message_delta
  └─ delta: { stop_reason: "end_turn"|"max_tokens"|"tool_use"|"stop_sequence" }
  └─ usage: { output_tokens, ... }

message_stop
Mid-stream error:

error
└─ error: { type: "overloaded_error"|"api_error"|..., message: "..." }
(stream terminates without message_stop)
The wire format per frame:

event: <name>\ndata: <json>\n\n
UTF-8 only. No id: or retry: fields are emitted on this surface.

§8.3 Tool-use partial-JSON accumulation
The input_json_delta chunks do not respect JSON boundaries — a single delta can split mid-token. The canonical pattern is to buffer per index and only JSON.parse(toolBuf[index]) when content_block_stop for that index arrives. This is the same pattern Worker A's translator uses to convert Anthropic→OpenAI on outbound. Worker C only needs the buffer for canary scanning — if the canary appears in tool input arguments rather than text, the operator should configure their canary detection accordingly (the default scan only inspects text_delta, since system-prompt-controlled output is what the PoC demonstrates).

§9 — OpenAI ↔ Anthropic Translator (Optional, env.WC_TRANSLATE)
When Worker A is OpenAI-compatible (LM Studio, OpenRouter, vLLM), Worker C transparently translates the response shape. Disabled by default — set env.WC_TRANSLATE=anthropic_to_openai or openai_to_anthropic to enable.

§9.1 OpenAI streaming chunk format
Per OpenAI Chat Completions streaming events reference9, each chunk is:

data: {"id":"chatcmpl-...","object":"chat.completion.chunk","created":<ts>,"model":"...","choices":[{"index":0,"delta":{"role":"assistant"|"<undefined>","content":"..."|null,"tool_calls":[...]},"finish_reason":null|"stop"|"tool_calls"|"length"}]}
Final chunk:

data: [DONE]
§9.2 16-case state machine
Anthropic event	OpenAI chunk	Notes
message_start	delta:{role:"assistant"}, finish_reason:null	first chunk
content_block_start (text, idx 0)	(suppressed; contents flow via deltas)	
content_block_start (tool_use, idx N)	delta:{tool_calls:[{index:N,id,type:"function",function:{name}}]}	tool_call header
content_block_delta (text_delta)	delta:{content:"<text>"}, finish_reason:null	direct map
content_block_delta (input_json_delta)	buffered; emit on stop as delta:{tool_calls:[{index:N,function:{arguments:"<json>"}}]}	accumulator
content_block_stop (text)	(no-op)	
content_block_stop (tool_use)	flush buffered tool args	
message_delta stop_reason=end_turn	delta:{}, finish_reason:"stop"	
message_delta stop_reason=max_tokens	delta:{}, finish_reason:"length"	
message_delta stop_reason=tool_use	delta:{}, finish_reason:"tool_calls"	
message_delta stop_reason=stop_sequence	delta:{}, finish_reason:"stop"	
message_stop	data: [DONE]\n\n then close	terminator
ping	(suppressed)	OpenAI clients don't expect pings
error (mid-stream)	data: {"error":{"message,type,code"}}\n\n then close	no [DONE]
(parallel tool_use, multiple blocks)	each gets its own tool_calls[index]	preserve index
(reasoning interleaving, future)	delta:{reasoning_content:"..."} (not yet standard)	passthrough only
The reverse direction (OpenAI→Anthropic) requires synthesizing message_start from the first chunk, opening content_block_start lazily on first delta.content, mapping finish_reason:"stop" back to stop_reason:"end_turn", and emitting [DONE] as message_stop. The 16-case table is symmetric except [DONE] and ping which only flow one way.

