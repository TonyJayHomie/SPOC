§3.1 Route resolution
// =============================================================================
// §3 ROUTING ENGINE
// =============================================================================

function resolveUpstream(env, pathAndQuery) {
  const route = (env.WC_ROUTE || 'test').toLowerCase();
  if (route === 'test') {
    if (!env.WORKER_A_URL) {
      throw new InterceptError(503, 'route=test requires env.WORKER_A_URL');
    }
    const base = env.WORKER_A_URL.replace(/\/$/, '');
    return { route, url: base + pathAndQuery };
  }
  if (route === 'passthrough') {
    return { route, url: 'https://api.anthropic.com' + pathAndQuery };
  }
  throw new InterceptError(503, `unknown WC_ROUTE: ${route}`);
}

function buildUpstreamHeaders(req, env, route) {
  const h = new Headers(req.headers);
  // Strip hop-by-hop and CF-injected headers
  [
    'host', 'cf-connecting-ip', 'cf-ipcountry', 'cf-ray', 'cf-visitor',
    'x-forwarded-for', 'x-forwarded-proto', 'x-real-ip',
    'content-length' // recomputed by fetch
  ].forEach(k => h.delete(k));

  if (route === 'passthrough') {
    // Inject HackerOne handle per Anthropic VDP research guidelines
    if (env.HACKERONE_HANDLE) {
      h.set('X-HackerOne-Handle', env.HACKERONE_HANDLE);
    }
    // Anthropic version pin
    if (!h.get('anthropic-version')) {
      h.set('anthropic-version', '2023-06-01');
    }
  }
  return h;
}
§4 — Setup UI at /setup
Operator-only diagnostics. Gated by a one-time setup token printed on first deploy and stored in KV under key WC_SETUP_TOKEN. Rotated on first successful POST to /api/worker-config.

§4.1 Token bootstrap
On first request to /setup, Worker C checks env.WC_KV.get('WC_SETUP_TOKEN'). If absent, it generates crypto.randomUUID(), stores it, and returns the token in the response body (one-shot — subsequent GETs return masked). Operator copies token to clipboard, then enters it in the form to authenticate the configuration POST.

§4.2 C2-fragment input rejection
Every form-submitted URL/string is validated against BLOCKED_HOSTS:

const BLOCKED_HOSTS = [
  'openclaude.111724.xyz',
  'cfc.aroic.workers.dev',
  '111724.xyz',
  'aroic.workers.dev',
];

function containsBlockedFragment(s) {
  if (!s) return false;
  const lower = s.toLowerCase();
  return BLOCKED_HOSTS.some(h => lower.includes(h));
}
If any field contains a CoCoDem C2 fragment, the POST is rejected 400 blocked_host_fragment.

