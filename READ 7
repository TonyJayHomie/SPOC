The interceptor is single-pass: request body is parsed once, mutated once, dispatched once. Response body is teed once — one branch flows back to the client byte-for-byte through an IdentityTransformStream, the other branch runs the canary detector and gets discarded. KV writes happen in ctx.waitUntil() so they don't block stream delivery, per the Cloudflare fetch handler ctx.waitUntil contract1.

§2 — The Five Mutation Modes
env.WC_MODE is read once per request. Default is passthrough. The five modes operate on parsedBody.system (top-level system field of /v1/messages JSON body), or on parsedBody.messages[*] if system is null and the operator has enabled WC_FALLBACK_MUTATE_USER (default off, off in this doc — system-only).

§2.1 Mode contract
Mode	env vars	Behavior
passthrough (default)	—	Log only. original_system captured to KV. Body forwarded unchanged. x-wc-system-stripped: false.
strip	—	delete parsedBody.system. x-wc-system-stripped: true, x-wc-final-system-len: 0.
replace	WC_REPLACEMENT	parsedBody.system = env.WC_REPLACEMENT. Refuses if WC_REPLACEMENT is unset.
prepend	WC_PREFIX	`parsedBody.system = env.WC_PREFIX + "\n\n" + (orig
append	WC_SUFFIX	`parsedBody.system = (orig
inject_canary	WC_CANARY (optional)	DEFAULT OFF — USER SET ONLY. Injects canary into system prompt; tee'd response stream is scanned for canary echo in text_delta events.
The inject_canary mode is the headline finding. It is off by default because it modifies model output, not just request payload. The operator must explicitly set WC_MODE=inject_canary in the Cloudflare dashboard env vars panel. If WC_CANARY is unset, Worker C refuses to inject and returns 503 inject_canary requires WC_CANARY.

§2.2 Mutation engine — code skeleton
// =============================================================================
// §2 MUTATION ENGINE
// =============================================================================

const VALID_MODES = new Set([
  'passthrough', 'strip', 'replace', 'prepend', 'append', 'inject_canary'
]);

function getMode(env) {
  const m = (env.WC_MODE || 'passthrough').toLowerCase();
  if (!VALID_MODES.has(m)) {
    throw new InterceptError(503, `unknown WC_MODE: ${m}`);
  }
  return m;
}

/**
 * Apply the configured mutation to a parsed /v1/messages JSON body.
 * Returns { mutated, original_system, final_system, canary }.
 *
 * Idempotent: never mutates input by reference; returns a new body object.
 */
function applyMutation(body, env, mode) {
  const original = body.system ?? null;
  const original_system = typeof original === 'string'
    ? original
    : Array.isArray(original)
      ? original.map(b => b?.text ?? '').join('\n')
      : '';

  // Deep-clone the body so the caller can compare original vs. mutated
  const mutated = structuredClone(body);
  let canary = null;

  switch (mode) {
    case 'passthrough':
      // log-only; body forwarded unchanged
      return { mutated, original_system, final_system: original_system, canary };

    case 'strip':
      delete mutated.system;
      return { mutated, original_system, final_system: '', canary };

    case 'replace': {
      if (!env.WC_REPLACEMENT) {
        throw new InterceptError(503, 'mode=replace requires env.WC_REPLACEMENT');
      }
      mutated.system = env.WC_REPLACEMENT;
      return { mutated, original_system, final_system: env.WC_REPLACEMENT, canary };
    }

    case 'prepend': {
      if (!env.WC_PREFIX) {
        throw new InterceptError(503, 'mode=prepend requires env.WC_PREFIX');
      }
      const final_system = env.WC_PREFIX + '\n\n' + original_system;
      mutated.system = final_system;
      return { mutated, original_system, final_system, canary };
    }

    case 'append': {
      if (!env.WC_SUFFIX) {
        throw new InterceptError(503, 'mode=append requires env.WC_SUFFIX');
      }
      const final_system = original_system + '\n\n' + env.WC_SUFFIX;
      mutated.system = final_system;
      return { mutated, original_system, final_system, canary };
    }

    case 'inject_canary': {
      // USER SET, DEFAULT OFF. Refuse if not explicitly configured.
      if (!env.WC_CANARY) {
        throw new InterceptError(503, 'mode=inject_canary requires env.WC_CANARY');
      }
      canary = env.WC_CANARY; // operator-supplied; never random-defaulted
      // The canary is injected as a system-prompt instruction. Form is
      // operator-controlled — Worker C does not prescribe wording.
      const canary_block = `[CANARY:${canary}]`;
      const final_system = original_system
        ? original_system + '\n\n' + canary_block
        : canary_block;
      mutated.system = final_system;
      return { mutated, original_system, final_system, canary };
    }
  }
}

class InterceptError extends Error {
  constructor(status, msg) { super(msg); this.status = status; }
}
The structuredClone call is available in Workers runtime per the standards-compliant API surface noted in Cloudflare's standards-compliant Workers API blog2.

