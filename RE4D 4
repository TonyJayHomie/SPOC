Copy/*
 * ============================================================================
 * SPOC Sister-PoC — DevTools Session Bridge (claude.ai)
 * ============================================================================
 *
 * Run instructions:
 *   1. Open claude.ai in a normal browser tab. Log in as usual.
 *   2. Open DevTools (F12) → Console.
 *   3. Edit WORKER_C_URL and SETUP_TOKEN below if not the defaults.
 *   4. Paste this entire file into the Console.
 *   5. Wait for "[SPOC-DTB] OK posted to Worker C" log line.
 *
 * What this script does:
 *   - fetch('/api/bootstrap/{org}/current_user_access', {credentials:'include'})
 *     and the equivalent /api/account_profile + /api/organizations
 *   - extracts org_uuid, account_uuid, redacted email, model list
 *   - POSTs metadata to Worker C /bridge/session with x-spoc-setup-token
 *
 * What this script does NOT do:
 *   - NEVER reads document.cookie
 *   - NEVER reads localStorage values containing credentials
 *   - NEVER moves the cookie value off-device — only the metadata bundle
 *     (org_uuid, account_uuid, redacted email) is posted, and that bundle is
 *     posted to the operator's OWN Worker C deployment, not to a third party
 *
 * REFUSAL HEADER:
 *   1. credentials:'include' is the ONLY auth mechanism — the browser supplies
 *      cookies; this script never sees them.
 *   2. Outbound POST is to env.WORKER_C_URL only (operator-owned).
 *   3. No third-party telemetry. No tracking.
 *   4. Single-operator, single-paste use. Not a persistent userscript.
 *   5. Setup-token gate prevents drive-by activation.
 *
 * Sources:
 *   CloudWaddie/LMArenaBridge — userscript proxy pattern
 *   W3C Fetch Standard §3.2 — credentials mode semantics
 *   NIST SP 800-63B-4 §7.2 — cookies as session-scoped credentials
 *   HackerOne anthropic VDP Safe Harbor (May 2026)
 * ============================================================================
 */

(async function spocDevToolsBridge() {
    'use strict';

    // ------------------- CONFIGURATION (operator edits these) -----------------
    const WORKER_C_URL = 'http://127.0.0.1:8787';   // operator's Worker C
    const SETUP_TOKEN  = '';                         // shared secret if set
    const VERBOSE      = true;
    // --------------------------------------------------------------------------

    const log = (...a) => VERBOSE && console.log('[SPOC-DTB]', ...a);
    const warn = (...a) => console.warn('[SPOC-DTB]', ...a);
    const err = (...a) => console.error('[SPOC-DTB]', ...a);

    // Step 1: fetch /api/account_profile to get the account.uuid + email
    let account = null;
    try {
        const r = await fetch('/api/account_profile', { credentials: 'include' });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        account = await r.json();
        log('account_profile fetched');
    } catch (e) {
        err('Failed to fetch /api/account_profile:', e.message);
        err('Are you logged in to claude.ai? Reload and try again.');
        return;
    }

    // Step 2: fetch /api/organizations to get the org list
    let orgs = null;
    try {
        const r = await fetch('/api/organizations', { credentials: 'include' });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        orgs = await r.json();
        log('organizations fetched:', orgs.length, 'org(s)');
    } catch (e) {
        err('Failed to fetch /api/organizations:', e.message);
        return;
    }

    if (!orgs || orgs.length === 0) {
        err('No organizations associated with this account.');
        return;
    }

    const primaryOrg = orgs[0];

    // Step 3: fetch /api/bootstrap/{org}/current_user_access for full identity
    let bootstrap = null;
    try {
        const r = await fetch(`/api/bootstrap/${primaryOrg.uuid}/current_user_access`, {
            credentials: 'include'
        });
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        bootstrap = await r.json();
        log('bootstrap fetched');
    } catch (e) {
        warn('Failed to fetch /api/bootstrap (non-fatal, falling back):', e.message);
    }

    // Step 4: fetch model list (Worker A needs this for Worker B's selector)
    let models = null;
    try {
        const r = await fetch(`/api/organizations/${primaryOrg.uuid}/model_configs/claude-sonnet-4-6`, {
            credentials: 'include'
        });
        if (r.ok) models = [{ model: 'claude-sonnet-4-6' }];
    } catch (_) { /* non-fatal */ }

    // Step 5: redact email — keep first 2 chars of local part + ***
    function redactEmail(emailStr) {
        if (!emailStr || typeof emailStr !== 'string') return null;
        const at = emailStr.indexOf('@');
        if (at < 1) return '***';
        const local = emailStr.slice(0, at);
        const domain = emailStr.slice(at);
        return local.slice(0, 2) + '***' + domain;
    }

    // Step 6: build metadata bundle (NO cookies, NO tokens, NO secrets)
    const bundle = {
        spoc_version: '7.0.0',
        ts: Date.now(),
        org_uuid: primaryOrg.uuid,
        org_name: primaryOrg.name || null,
        account_uuid: account.uuid,
        user_email_redacted: redactEmail(account.email_address),
        memberships_count: bootstrap ? (bootstrap.account?.memberships?.length || 0) : null,
        capabilities: primaryOrg.capabilities || [],
        rate_limits: primaryOrg.rate_limits || null,
        models: models,
        bootstrap_present: !!bootstrap,
        // NO cookie value, NO sessionKey, NO bearer, NO API key — verify by inspection
    };

    log('Bundle (about to POST):', bundle);

    // Step 7: POST to Worker C /bridge/session — operator-owned endpoint only
    try {
        const headers = { 'content-type': 'application/json' };
        if (SETUP_TOKEN) headers['x-spoc-setup-token'] = SETUP_TOKEN;

        const r = await fetch(`${WORKER_C_URL}/bridge/session`, {
            method: 'POST',
            headers,
            body: JSON.stringify(bundle),
            // Note: credentials:'omit' on Worker C POST — we are NOT sending claude.ai
            // cookies to Worker C. Worker C is a separate origin.
            credentials: 'omit',
            mode: 'cors'
        });

        if (!r.ok) {
            err(`Worker C POST failed: HTTP ${r.status}`);
            const text = await r.text().catch(() => '');
            err('Response:', text.slice(0, 300));
            return;
        }

        log('OK posted to Worker C — Worker C now knows org_uuid =', bundle.org_uuid);
    } catch (e) {
        err('Failed to POST to Worker C:', e.message);
        err(`Is Worker C running at ${WORKER_C_URL}?`);
        return;
    }

    // Step 8: print summary for operator confirmation
    console.log('%c[SPOC-DTB] Complete', 'color:#ffb000; font-weight:bold; font-size:14px');
    console.table({
        org_uuid: bundle.org_uuid,
        account_uuid: bundle.account_uuid,
        email: bundle.user_email_redacted,
        capabilities: (bundle.capabilities || []).join(','),
        models: (bundle.models || []).map(m => m.model).join(',')
    });
})();
