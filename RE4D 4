The 12/14-byte tail-retention is critical: SSE chunks split mid-tag almost every time, and naive indexOf against a fresh chunk misses tags that straddle two chunks.

4. Sandboxed Artifact Iframe
For text/html and application/vnd.ant.react artifacts, render in a sandboxed <iframe sandbox="allow-scripts"> (no allow-same-origin unless absolutely required). Inject window.claude.complete so the artifact can call back into the host for sub-completions.

iframe construction
Copyfunction mountArtifactIframe(artifact, parentEl) {
  const iframe = document.createElement('iframe');
  iframe.setAttribute('sandbox', 'allow-scripts');
  iframe.style.cssText = 'width:100%;height:100%;border:0;background:#fff';
  parentEl.appendChild(iframe);

  const html = artifact.type === 'application/vnd.ant.react'
    ? buildReactHostHTML(artifact.content)
    : artifact.content;  // text/html

  // srcdoc carries the doc; window.claude.complete is bound via postMessage
  iframe.srcdoc = html;
  iframe.addEventListener('load', () => bindClaudeAPI(iframe, artifact));
}

function buildReactHostHTML(jsx) {
  return `<!doctype html><html><head>
    <meta charset="utf-8">
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>body{margin:0;font-family:system-ui;padding:1rem}</style>
  </head><body><div id="root"></div>
  <script type="text/babel" data-presets="react,env">
    ${jsx}
    const App = (typeof exports !== 'undefined' && exports.default) || window.default || (() => null);
    ReactDOM.createRoot(document.getElementById('root')).render(React.createElement(App));
