State machine
class ArtifactParser {
  constructor(onArtifact, onUpdate, onClose) {
    this.buf = '';
    this.state = 'TEXT';            // 'TEXT' | 'IN_OPEN_TAG' | 'IN_BODY' | 'IN_CLOSE_TAG'
    this.current = null;            // { identifier, type, language, title, content }
    this.onArtifact = onArtifact;   // fired on first byte of body (mounts the panel)
    this.onUpdate = onUpdate;       // fired on every body delta (Monaco append)
    this.onClose = onClose;         // fired on </antArtifact>
  }
  feed(chunk) {
    this.buf += chunk;
    while (this.buf.length) {
      if (this.state === 'TEXT') {
        const i = this.buf.indexOf('<antArtifact');
        if (i === -1) {
          // Emit prefix as visible text, but keep last 12 bytes in case '<antArtifac' arrives split
          if (this.buf.length > 12) {
            this.emitText(this.buf.slice(0, -12));
            this.buf = this.buf.slice(-12);
          }
          return;
        }
        if (i > 0) this.emitText(this.buf.slice(0, i));
        this.buf = this.buf.slice(i);
        this.state = 'IN_OPEN_TAG';
      }
      if (this.state === 'IN_OPEN_TAG') {
        const close = this.buf.indexOf('>');
        if (close === -1) return;   // wait for more
        const tag = this.buf.slice(0, close + 1);
        this.current = this.parseAttrs(tag);
        this.current.content = '';
        this.onArtifact(this.current);  // mount the panel now, body to follow
        this.buf = this.buf.slice(close + 1);
        this.state = 'IN_BODY';
      }
      if (this.state === 'IN_BODY') {
        const end = this.buf.indexOf('</antArtifact>');
        if (end === -1) {
          // Emit body so far, but keep last 14 bytes in case '</antArtifact' arrives split
          if (this.buf.length > 14) {
            const slice = this.buf.slice(0, -14);
            this.current.content += slice;
            this.onUpdate(this.current, slice);
            this.buf = this.buf.slice(-14);
          }
          return;
        }
        const slice = this.buf.slice(0, end);
        this.current.content += slice;
        this.onUpdate(this.current, slice);
        this.onClose(this.current);
        this.buf = this.buf.slice(end + '</antArtifact>'.length);
        this.current = null;
        this.state = 'TEXT';
      }
    }
  }
  parseAttrs(tag) {
    const out = {};
    for (const m of tag.matchAll(/(\w+)="([^"]*)"/g)) out[m[1]] = m[2];
    return out;
  }
  emitText(s) { /* dispatch to message renderer */ }
}
