window.claude.complete injection (postMessage protocol)
The iframe can't directly call the parent's fetch (different origin under sandbox), so we bridge via postMessage:

// In the parent (Worker B SPA)
function bindClaudeAPI(iframe, artifact) {
  window.addEventListener('message', async (ev) => {
    if (ev.source !== iframe.contentWindow) return;
    if (ev.data?.type !== 'claude.complete.request') return;
    const { id, prompt, options } = ev.data;
    // Route through the SAME outbound path as the main chat — Worker C/A
    const resp = await fetch(`${WORKER_C_URL}/api/organizations/${ORG_UUID}/proxy/v1/messages`, {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'anthropic-version': '2023-06-01',
        'anthropic-client-platform': 'web_claude_ai',
        'anthropic-device-id': DEVICE_ID
      },
      body: JSON.stringify({
        model: options?.model || 'claude-opus-4-7',
        max_tokens: options?.max_tokens || 4096,
        messages: [{ role: 'user', content: prompt }]
      })
    });
    const result = await resp.json();
    iframe.contentWindow.postMessage({ type: 'claude.complete.response', id, result }, '*');
  });
}

// Inside the iframe (injected into srcdoc via the React host template)
window.claude = {
  complete: function(prompt, options = {}) {
    return new Promise((resolve, reject) => {
      const id = crypto.randomUUID();
      const handler = (ev) => {
        if (ev.data?.type !== 'claude.complete.response' || ev.data.id !== id) return;
        window.removeEventListener('message', handler);
        resolve(ev.data.result.content[0].text);
      };
      window.addEventListener('message', handler);
      window.parent.postMessage({ type: 'claude.complete.request', id, prompt, options }, '*');
      setTimeout(() => { window.removeEventListener('message', handler); reject(new Error('timeout')); }, 120_000);
    });
  }
};
