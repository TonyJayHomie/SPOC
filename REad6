Loading the SPA
Inside the Worker B Cloudflare Worker:

export default {
  async fetch(request, env) {
    const url = new URL(request.url);

    // Static assets
    if (url.pathname === '/' || url.pathname === '/new' || url.pathname.startsWith('/chat/')) {
      const html = SPA_HTML
        .replace('__WORKER_A_URL__', env.WORKER_A_URL || 'http://127.0.0.1:8787')
        .replace('__WORKER_C_URL__', env.WORKER_C_URL || 'ws://127.0.0.1:8787/ws')
        .replace('__VERSION__', env.SPA_VERSION || '1.0.0');
      return new Response(html, {
        headers: {
          'content-type': 'text/html; charset=utf-8',
          'content-security-policy': env.CSP_MODE === 'strict' ? STRICT_CSP : '',
          'x-frame-options': 'DENY',
          'x-content-type-options': 'nosniff',
          'referrer-policy': 'strict-origin-when-cross-origin'
        }
      });
    }

    // Health
    if (url.pathname === '/health') return Response.json({ ok: true, version: env.SPA_VERSION });

    return new Response('Not found', { status: 404 });
  }
};

