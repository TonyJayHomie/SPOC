5. SSE Consumer State Machine
Anthropic SSE event-stream format: each event is event: <name>\ndata: <json>\n\n. UTF-8 only, no id: or retry: fields on the consumer surface. The seven event types in the consumer surface:

message_start — initial frame with the message object and initial usage.input_tokens
content_block_start — opens a block at a specific index, type is text or tool_use or thinking
ping — keepalive every ~15s, can appear anywhere
content_block_delta — multiple per block, deltas are text_delta, input_json_delta, or thinking_delta
content_block_stop — closes a block; tool-use JSON is now safe to JSON.parse
message_delta — final stop_reason and cumulative usage.output_tokens
message_stop — final framing event; stream closes after
Plus error for mid-stream errors (terminates without message_stop).

Frame parser
class SSEParser {
  constructor(onEvent) {
    this.buf = '';
    this.onEvent = onEvent;
    this.decoder = new TextDecoder('utf-8', { fatal: false });
  }
  async consume(stream) {
    const reader = stream.getReader();
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      this.buf += this.decoder.decode(value, { stream: true });
      let idx;
      while ((idx = this.buf.indexOf('\n\n')) !== -1) {
        const frame = this.buf.slice(0, idx);
        this.buf = this.buf.slice(idx + 2);
        this.dispatch(frame);
      }
    }
    if (this.buf.trim()) this.dispatch(this.buf);
  }
  dispatch(frame) {
    let event = 'message', data = '';
    for (const line of frame.split('\n')) {
      if (line.startsWith('event:')) event = line.slice(6).trim();
      else if (line.startsWith('data:')) data += (data ? '\n' : '') + line.slice(5).trim();
    }
    if (!data) return;
    let parsed;
    try { parsed = JSON.parse(data); } catch { return; }
    this.onEvent(event, parsed);
  }
}
Block accumulator (the canonical pattern)
class MessageAccumulator {
  constructor() {
    this.blocks = [];        // index → { type, text?, name?, input_buf? }
    this.usage = { input_tokens: 0, output_tokens: 0 };
    this.stop_reason = null;
    this.message_id = null;
    this.model = null;
  }
  apply(event, payload) {
    switch (event) {
      case 'message_start':
        this.message_id = payload.message.id;
        this.model = payload.message.model;
        this.usage.input_tokens = payload.message.usage.input_tokens;
        break;
      case 'content_block_start':
        this.blocks[payload.index] = payload.content_block.type === 'tool_use'
          ? { type: 'tool_use', id: payload.content_block.id, name: payload.content_block.name, input_buf: '' }
          : payload.content_block.type === 'thinking'
          ? { type: 'thinking', text: '' }
          : { type: 'text', text: '' };
        break;
      case 'content_block_delta': {
        const blk = this.blocks[payload.index];
        if (!blk) return;
        if (payload.delta.type === 'text_delta') blk.text += payload.delta.text;
        else if (payload.delta.type === 'thinking_delta') blk.text += payload.delta.thinking;
        else if (payload.delta.type === 'input_json_delta') blk.input_buf += payload.delta.partial_json;
        break;
      }
      case 'content_block_stop': {
        const blk = this.blocks[payload.index];
        if (blk?.type === 'tool_use') {
          try { blk.input = JSON.parse(blk.input_buf || '{}'); }
          catch (e) { blk.input = {}; blk.parse_error = e.message; }
          delete blk.input_buf;
        }
        break;
      }
      case 'message_delta':
        this.stop_reason = payload.delta.stop_reason;
        this.usage.output_tokens = payload.usage.output_tokens;
        break;
      case 'message_stop':
        // finalize
        break;
      case 'error':
        this.error = payload.error;
        break;
      case 'ping':
        break;
    }
  }
}
The input_json_delta chunks do not respect JSON boundaries — a single delta might be {"qu and the next ery":"foo"}. Buffer until content_block_stop, then parse. Multiple tool-use blocks in one message use distinct index values; a 3-tool-call message has indices 0,1,2 each independently buffering.

Reasoning interleaving: when extended_thinking is enabled, thinking blocks arrive before visible text blocks. Render them in a collapsible <details> panel and switch the visible content area to the next text block when its content_block_start fires.

Source: kotrotsos's Claude Code Internals Part 7 — SSE Stream Processing4 covers the exact buffer+parse pattern; Anthropic's published streaming docs ratify the event taxonomy.

6. IndexedDB Schema
Six object stores. Use raw onupgradeneeded (no Dexie dependency, keeps the bundle small). Schema version 3 (account for two migrations).

const DB_NAME = 'worker_b_spa';
const DB_VERSION = 3;

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onerror = () => reject(req.error);
    req.onsuccess = () => resolve(req.result);
    req.onupgradeneeded = (ev) => {
      const db = req.result;
      const oldV = ev.oldVersion;

      if (oldV < 1) {
        const conv = db.createObjectStore('conversations', { keyPath: 'uuid' });
        conv.createIndex('updated_at', 'updated_at');
        conv.createIndex('model', 'model');
        conv.createIndex('project_uuid', 'project_uuid');

        const msg = db.createObjectStore('messages', { keyPath: 'uuid' });
        msg.createIndex('conv_uuid', 'conv_uuid');
        msg.createIndex('created_at', 'created_at');
        msg.createIndex('parent_message_uuid', 'parent_message_uuid');

        db.createObjectStore('settings', { keyPath: 'key' });

        const models = db.createObjectStore('models', { keyPath: 'id' });
        models.createIndex('provider', 'provider');
        models.createIndex('display_name', 'display_name');
      }
      if (oldV < 2) {
        const att = db.createObjectStore('attachments', { keyPath: 'uuid' });
        att.createIndex('conv_uuid', 'conv_uuid');
        att.createIndex('file_name', 'file_name');
      }
      if (oldV < 3) {
        const logs = db.createObjectStore('logs', { keyPath: 'id', autoIncrement: true });
        logs.createIndex('ts', 'ts');
        logs.createIndex('request_id', 'request_id');
      }
    };
  });
}
Helper wrappers
function tx(db, stores, mode = 'readonly') {
  return db.transaction(stores, mode);
}
function put(db, store, value) {
  return new Promise((resolve, reject) => {
    const r = tx(db, [store], 'readwrite').objectStore(store).put(value);
    r.onsuccess = () => resolve(r.result);
    r.onerror = () => reject(r.error);
  });
}
function getAllByIndex(db, store, indexName, range) {
  return new Promise((resolve, reject) => {
    const idx = tx(db, [store]).objectStore(store).index(indexName);
    const r = idx.getAll(range);
    r.onsuccess = () => resolve(r.result);
    r.onerror = () => reject(r.error);
  });
}
